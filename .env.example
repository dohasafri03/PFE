# Example environment variables for marche_ai_platform
# Copy this file to `.env` and fill values. DO NOT commit `.env` with secrets.

# Scraping / authentication
SCRAPING_LOGIN_ENABLED=false
SCRAPING_LOGIN_USERNAME=
SCRAPING_LOGIN_PASSWORD=
SCRAPING_LOGIN_ENDPOINT=/index.php?page=entreprise.EntrepriseConnexion
SCRAPING_USE_PLAYWRIGHT=false
SCRAPING_BASE_URL=https://www.marchespublics.gov.ma/
SCRAPING_DELAY_MIN=1.0
SCRAPING_DELAY_MAX=3.0
SCRAPING_TIMEOUT=30
SCRAPING_MAX_RETRIES=3

# NLP / models (optional)
SPACY_MODEL=fr_core_news_md
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
SIMILARITY_THRESHOLD=0.75

# API settings
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Document generation
TEMPLATE_DIR=templates
OUTPUT_DIR=data/generated_docs
